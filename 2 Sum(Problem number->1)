class Solution {
public:
    vector<int> twoSum(vector<int>& nums, int target) {
        unordered_map<int,int>m;
        int n=nums.size();
        for(int i=0;i<n;i++)
        {
            int first=nums[i];
            int sec=target-first;
            if(m.find(sec)!=m.end())
                return {i,m[sec]};

            m[first]=i;
        }
        return {};
    }
};

# TC: O(n)
