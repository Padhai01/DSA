# Approach 1

class Solution {
public:
    bool isPalindrome(string s) {
        int n=s.length();
        for(int i=0;i<n;i++)
            s[i]=tolower(s[i]);
        string st,str;
        for(int i=0;i<n;i++)
        {
            if((s[i]>='a' && s[i]<='z') || (s[i]>='0' && s[i]<='9'))
                st+=s[i];
        }
        str=st;
        reverse(st.begin(),st.end());

        if(str==st)
            return true;

        else
            return false;
    }
};
