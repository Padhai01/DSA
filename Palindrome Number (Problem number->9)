class Solution {
public:
    bool isPalindrome(int x) {
        if(x<0)
            return false;

        int newn=x;
        int n=0;
        while(x!=0)
        {
            int d=0;
            d=x%10;
            x=x/10;
            if(n>INT_MAX/10 || n<INT_MIN/10)
                return 0;

            n=n*10+d;
        }
        if(newn==n)
            return true;

        else
            return false;
    }
};
