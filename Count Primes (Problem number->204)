# Approach 1 -very basic

class Solution {
public:
    int countPrimes(int n) {
        if(n==0)
            return 0;

        if(n==1)
            return 0;

        int count=0;
        for(int i=2;i<n;i++)
        {
            int c=0;
            for(int j=1;j<=i;j++)
            {
                if(i%j==0)
                    c++;
            }
            if(c==2)
                count++;
        }
        return count;
    }
};
