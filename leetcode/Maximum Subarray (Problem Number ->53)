# Approach 1

class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        int n=nums.size();
        int maxSum=0;
        for(int st=0;st<n;st++)
        {
            int curSum=0;
            for(int end=st;end<n;end++)
            {
                curSum+=nums[end];

                if(curSum>maxSum)
                    maxSum=curSum;
            }
        }
        return maxSum;
    }
};
