# Approach 2

class Solution {
public:
    bool isAlphanum(char a)
    {
        if((tolower(a)>='a' && tolower(a)<='z') || (a>='0' && a<='9'))
            return true;

        else
            return false;
    }
    bool isPalindrome(string s) {
        int st=0,e=s.length()-1;
        while(st<e)
        {
            if(!isAlphanum(s[st]))
            {
                st++;
                continue;
            }
            if(!isAlphanum(s[e]))
            {
                e--;
                continue;
            }

            if(tolower(s[st])!=tolower(s[e]))
                return false;

            st++;e--;
        }
        return true;
    }
};
