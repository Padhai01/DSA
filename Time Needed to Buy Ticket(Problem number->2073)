# Approach 2

class Solution {
public:
    int timeRequiredToBuy(vector<int>& tickets, int k) {
        int n=tickets.size();
        int time=0;
        int tk=tickets[k];
        for(int i=0;i<n;i++)
        {
            if(i<=k)
                time+=min(tickets[i],tk);

            else
                time+=min(tickets[i],tk-1);
        }
        return time;
    }
};

# tc=O(n)
# sc=O(1)
