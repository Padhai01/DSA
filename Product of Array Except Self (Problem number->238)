# brute force

class Solution {
public:
    vector<int> productExceptSelf(vector<int>& nums) {
        vector<int> answer(nums.size(),1);
        for(int i=0;i<nums.size();i++)
        {
            int ans=1;
            for(int j=0;j<nums.size();j++)
            {
                if(i!=j)
                    ans*=nums[j];
            }
            answer[i]=ans;
        }
        return answer;
    }
};

# TC: O(n2)
# SC: O(n)
